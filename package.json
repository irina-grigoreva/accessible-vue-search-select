{
  "name": "accessible-vue-search-select",
  "version": "0.1.0",
  "description": "Accessible Vue 3 searchable select / combobox component with TypeScript support.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "keywords": [
    "vue",
    "vue3",
    "select",
    "combobox",
    "search-select",
    "accessible",
    "a11y",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/accessible-vue-search-select.umd.cjs",
  "module": "./dist/accessible-vue-search-select.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/accessible-vue-search-select.js",
      "require": "./dist/accessible-vue-search-select.umd.cjs"
    },
    "./style.css": "./dist/accessible-vue-search-select.css"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "dev": "vite --host 127.0.0.1",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^25.9.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.27.0",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.3.5",
    "vitest": "^3.1.4",
    "vue": "^3.5.16",
    "vue-tsc": "^2.2.10"
  }
}
